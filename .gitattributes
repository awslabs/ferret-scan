# Enforce LF line endings so byte-for-byte comparisons (notably the
# internal/goldencorpus snapshot tests) are identical across operating systems.
# Without this, git's autocrlf converts text files to CRLF on Windows checkout,
# which diverges from the LF-committed golden fixtures and the LF output the
# formatters produce — breaking the windows-latest CI golden tests.

# Golden snapshot fixtures: always LF, treat as text with fixed eol.
internal/goldencorpus/testdata/golden/** text eol=lf

# Go sources and common text formats: normalize to LF in the repo and on checkout.
*.go    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.csv   text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
